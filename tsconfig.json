{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "strict": true,

    "types": ["node"],
    "lib": ["ES2023"],

    "esModuleInterop": true,
    "skipLibCheck": true,

    "declaration": true,
    "sourceMap": true
  },
  "include": ["src", "test", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "test/fixtures"]
}
