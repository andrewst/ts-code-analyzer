{
  "name": "ts-code-analyzer",
  "version": "0.0.1",
  "description": "Static analysis utility for detecting dead code in TypeScript libraries",
  "keywords": [
    "typescript",
    "static-analysis",
    "dead-code",
    "ast",
    "code-quality"
  ],
  "homepage": "https://github.com/andrewst/ts-code-analyzer#readme",
  "license": "MIT",
  "author": "Andrei Stoetskii <andrew.stoetskiy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:andrewst/ts-code-analyzer.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "detect-dead-code": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc --watch --noEmit",
    "dev-go": "tsgo --watch --noEmit",
    "build": "tsc",
    "build-go": "tsgo",
    "start": "tsx ./src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "oxlint": "oxlint",
    "oxlint:fix": "oxlint --fix",
    "lint": "concurrently --names 'LINT,FMT' 'pnpm oxlint' 'pnpm format:check'",
    "lint:fix": "concurrently --names 'LINT,FMT' 'pnpm oxlint:fix' 'pnpm format'",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\""
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260413.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  }
}
