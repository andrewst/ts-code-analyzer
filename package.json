{
  "name": "ts_code_analyzer",
  "version": "0.0.1",
  "description": "A static analysis utility for detecting dead code in TypeScript libraries. Identifies exported symbols that are not consumed by the public API, library source code, or are only used in tests/demo code.",
  "main": "dist/index.js",
  "bin": {
    "detect-dead-code": "dist/index.js"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build-go": "tsgo",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "rebuild": "pnpm clean && pnpm build"
  },
  "keywords": [
    "typescript",
    "static-analysis",
    "dead-code-detection",
    "code-quality",
    "ast-parser"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": ""
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260413.1",
    "typescript": "~6.0.2"
  },
  "private": true
}
